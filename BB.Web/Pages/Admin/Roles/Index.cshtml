@page
@model BB.Web.Pages.Admin.Roles.IndexModel
@{
}
<div class="border backgroundWhite container">
    <div class="row">
        <div class="col-6">
            <h2 class="text-primary">Role List</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-page="Upsert" class="btn btn-primary"><i class="fas fa-plus"></i> &nbsp; Create New</a>
        </div>
    </div>
    <br /><br />
    <p class="d-none" id="success">@Model.Success.ToString()</p>
    <p class="d-none" id="message">@Model.Message</p>
    <table id="DT_Roles" class="table table-striped table-bordered" style="width:100%">
        <thead>
            <tr>
                <th scope="col">Role</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var role in Model.RolesObj)
            {
                <tr>
                    <td>@role.Name</td>
                    <td>
                        <a class="btn btn-outline-success" asp-page="Upsert" asp-route-id="@role.Id.ToString()">Update</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#DT_Roles").DataTable({
                "pageLength": 10,
                "lengthMenu": [[5, 10, 25, -1], [5, 10, 25, "All"]],
                "order": [[0, "asc"]]
            });
        });

        function alertFunc() {
            var success = $("#success").html();
            var message = $("#message").html();
            if (success == "True") {
                toastr.success(message);
            }
        }
        window.onload = alertFunc;
    </script>
}
